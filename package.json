{
  "name": "flexbook",
  "displayName": "FlexBook",
  "description": "A notebook-style terminal where commands are structured, reusable, and composable — directly in VS Code.",
  "version": "1.0.0",
  "publisher": "FlexBook",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xdaksh-12/FlexBook.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "terminal",
    "shell",
    "notebook",
    "developer tools",
    "workflow"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Notebooks"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flexbook.newFile",
        "title": "FlexBook: New File"
      }
    ],
    "customEditors": [
      {
        "viewType": "flexbook.editor",
        "displayName": "FlexBook Editor",
        "selector": [
          {
            "filenamePattern": "*.ftx"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "build:css": "npx @tailwindcss/cli -i ./src/webview/styles.css -o ./dist/webview.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./src/webview/styles.css -o ./dist/webview.css --watch",
    "compile": "pnpm run build:css && pnpm run check-types && pnpm run lint && node esbuild.js",
    "compile:extension": "node esbuild.js",
    "compile:webview": "node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run build:css && pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json -w",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "npm-run-all -p test:*",
    "test:unit": "vitest run -c vitest.config.mts src/tests/unit",
    "test:integration": "vitest run -c vitest.config.mts src/tests/integration",
    "test:extension": "vscode-test",
    "test:webview": "vitest run -c vitest.config.webview.mts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-themes": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vscode/codicons": "^0.0.44",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "ansi-to-react": "^6.2.6",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "immer": "^11.1.4",
    "jsdom": "^29.0.1",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.1"
  },
  "vsce": {
    "dependencies": false
  }
}
