{
  "name": "fluxterm",
  "displayName": "FluxTerm",
  "description": "FluxTerm is a modern VS Code extension that reimagines the terminal experience. Inspired by tools like Warp and Wave, FluxTerm brings features like intelligent autocomplete, multi-log monitoring, split view with drag-and-drop, and powerful command chaining — all within your editor.",
  "version": "1.0.0",
  "publisher": "0xflame-7",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xflame-7/FluxTerm.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "terminal",
    "vscode",
    "shell",
    "developer tools"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fluxterm.newFile",
        "title": "FluxTerm: New File"
      }
    ],
    "customEditors": [
      {
        "viewType": "fluxterm.editor",
        "displayName": "FluxTerm Editor",
        "selector": [
          {
            "filenamePattern": "*.ftx"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "build:css": "npx @tailwindcss/cli -i ./src/webview/styles.css -o ./dist/webview.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./src/webview/styles.css -o ./dist/webview.css --watch",
    "compile": "pnpm run build:css && pnpm run check-types && pnpm run lint && node esbuild.js",
    "compile:extension": "node esbuild.js",
    "compile:webview": "node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run build:css && pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir dist",
    "watch-tests": "tsc -p . -w --outDir dist",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "npm-run-all -p test:*",
    "test:unit": "vitest run -c vitest.config.mts src/tests/unit",
    "test:integration": "vitest run -c vitest.config.mts src/tests/integration",
    "test:extension": "vscode-test",
    "test:webview": "vitest run -c vitest.config.webview.mts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@vscode/codicons": "^0.0.44",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "ansi-to-react": "^6.2.6",
    "chai": "^6.2.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "immer": "^11.1.4",
    "jsdom": "^29.0.1",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "vsce": {
    "dependencies": false
  }
}
